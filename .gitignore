# Test artifacts — pytest basetemp leaks to repo root when run from repo root
# (pytest-of-<user>/) and some tests create uncleaned tmp* dirs. Ignore so they
# never pollute `git status` or risk accidental commits.
pytest-of-*/
tmp*/

# Ignore files
logs/
session.checkpoint.timings.jsonl

# Virtual Environment
venv/
ENV/

# Environment Variables
.env

# IDE
.idea/
.vscode/
*.swp
*.swo
.cursorrules
.cursorignore
.cursorindexingignore

# OS
.DS_Store
Thumbs.db

# graph
*.png

# Txt files
*.txt

# PDF files
*.pdf

# Frontend
node_modules

# Outputs
outputs/

# Database files (users will have their own local databases)
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Persistent tushare cache (relocated via DISK_CACHE_PATH) — covers db + WAL sidecars
# (*.sqlite matches the db but not cache.sqlite-wal / cache.sqlite-shm)
data/cache/

# Local git worktrees
.worktrees/

# Alembic (keep migration files, but ignore generated/cache files)
app/backend/alembic/versions/__pycache__/
.claude/scheduled_tasks.lock
uv.lock

# Coverage data
.coverage

# Local report files
r.json
r.md
data/feature_cache/
data/paper_trading/
